{
  "name": "postgreselectric",
  "dev": {
    "services": {
      "postgres": {
        "kind": "postgres",
        "mode": "local",
        "version": "18",
        "isolation": "database",
        "project": "postgreselectric",
        "parent_branch": "main",
        "parent_database": "postgreselectric_main",
        "branch_policy": "worktree",
        "branch_name_template": "{app}/{git_branch}",
        "ttl": "168h",
        "database": "postgreselectric",
        "role": "scenery",
        "database_url_env": "DatabaseURL"
      },
      "electric": {
        "kind": "electric",
        "mode": "local",
        "isolation": "database",
        "branch_policy": "manual",
        "database": "postgres",
        "route": "electric",
        "env": {
          "DATABASE_URL": "$DatabaseURL",
          "ELECTRIC_USAGE_REPORTING": "false"
        }
      }
    }
  }
}
