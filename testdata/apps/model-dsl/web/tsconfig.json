{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@scenery/generated": ["../.scenery/gen/web/web/index.ts"],
      "@scenery/generated/*": ["../.scenery/gen/web/web/*"],
      "@scenery/layout-kit": ["src/scenery-layout-kit.ts"],
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../.scenery/gen/web/web/**/*.ts",
    "../.scenery/gen/web/web/**/*.tsx"
  ]
}
