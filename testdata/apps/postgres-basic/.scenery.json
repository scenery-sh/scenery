{
  "name": "postgresbasic",
  "dev": {
    "services": {
      "postgres": {
        "kind": "postgres",
        "mode": "local",
        "version": "18",
        "isolation": "database",
        "project": "postgresbasic",
        "parent_branch": "main",
        "parent_database": "postgresbasic_main",
        "branch_policy": "worktree",
        "branch_name_template": "{app}/{git_branch}",
        "ttl": "168h",
        "database": "postgresbasic",
        "role": "scenery",
        "database_url_env": "DatabaseURL"
      }
    }
  }
}
