package "service" {

  go_contract {
    import_path = "example.com/basicapp/service"
  }
}

input "gateway" {
  type = resource_ref("http_gateway")
}

service "service" {
  runtime = "go"

  implementation {
    constructor = "NewService"
  }
}

record "echo_input" {
  field "message" {
    type = string
  }
}

record "echo_result" {
  field "message" {
    type = string
  }
}

operation "echo" {
  service = service.service
  input   = record.echo_input

  handler {
    method = "Echo"
  }

  result "ok" {
    type = record.echo_result
  }
}

execution "echo_direct" {
  operation = operation.echo
  mode      = "direct"
  timeout   = "30s"
}

binding "echo_http" {
  gateway   = var.gateway
  operation = operation.echo
  execution = execution.echo_direct
  protocol  = "http"
  delivery  = "call"

  authentication = std.authentication.none
  authorization  = std.authorization.public
  pipeline       = std.pipeline.empty

  http {
    method        = "POST"
    path          = "/echo"
    codec_profile = std.codec.http_json_v1

    body {
      codec = "json"
      to    = operation.echo.input
    }

    response "ok" {
      when   = result.ok
      status = 200

      body {
        codec = "json"
        from  = result.ok
      }
    }
  }
}
