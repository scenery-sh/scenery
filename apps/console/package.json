{
  "name": "console",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "profile:query-table": "cd ../.. && apps/console/node_modules/.bin/tsc -p apps/console/tsconfig.profiler.json && bun --preload ./apps/console/perf/query-table-profiler-mocks.tsx ./apps/console/perf/query-table-profiler.bench.tsx",
    "preview": "vite preview"
  },
  "dependencies": {
    "@astryxdesign/core": "^0.1.7",
    "@astryxdesign/theme-neutral": "^0.1.2",
    "@stylexjs/stylex": "0.18.3",
    "@tanstack/react-query": "^5.101.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astryxdesign/build": "^0.1.2",
    "@stylexjs/babel-plugin": "0.18.3",
    "@stylexjs/unplugin": "0.18.3",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-test-renderer": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "react-test-renderer": "19.2.7",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
