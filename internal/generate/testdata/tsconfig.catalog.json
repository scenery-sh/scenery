    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "@astryxdesign/core/*": [
        "../../../apps/console/node_modules/@astryxdesign/core/dist/*/index.d.ts",
