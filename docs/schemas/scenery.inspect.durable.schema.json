{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.inspect.durable.schema.json",
  "title": "scenery.inspect.durable",
  "type": "object",
  "required": [
    "kind",
    "schema_revision",
    "app",
    "durable",
    "declarations",
    "services"
  ],
  "properties": {
    "kind": {
      "const": "scenery.inspect.durable"
    },
    "schema_revision": {
      "const": "sha256:2e767f9bda8f938a8ef91a1c386f509dd1aafd7ae032d6e56ed14e79fca35c56"
    },
    "app": {
      "$ref": "#/$defs/appRef"
    },
    "durable": {
      "type": "object",
      "required": [
        "database",
        "schema",
        "task_count",
        "service_count"
      ],
      "properties": {
        "database": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "schema": {
          "const": "scenery"
        },
        "task_count": {
          "type": "integer",
          "minimum": 0
        },
        "service_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "declarations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "name",
          "service",
          "schema",
          "file",
          "line"
        ],
        "properties": {
          "kind": {
            "const": "durable_task"
          },
          "name": {
            "type": "string"
          },
          "service": {
            "type": "string"
          },
          "schema": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "line": {
            "type": "integer",
            "minimum": 0
          },
          "input": {
            "type": "string"
          },
          "output": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "schema"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "schema": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "appRef": {
      "type": "object",
      "required": [
        "name",
        "root",
        "config_path"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "root": {
          "type": "string"
        },
        "config_path": {
          "type": "string"
        },
        "module_path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
