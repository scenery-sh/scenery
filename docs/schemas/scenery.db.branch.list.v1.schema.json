{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.db.branch.list.v1.schema.json",
  "title": "scenery db branch list",
  "type": "object",
  "required": ["schema_version", "ok", "app", "provider", "branches"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "scenery.db.branch.list.v1" },
    "ok": { "type": "boolean" },
    "app": { "type": "object" },
    "provider": { "const": "sqlite" },
    "branches": {
      "type": "array",
      "items": { "$ref": "#/$defs/pin" }
    },
    "leases": {
      "type": "array",
      "items": { "$ref": "#/$defs/lease" }
    },
    "registry_path": { "type": "string" },
    "message": { "type": "string" }
  },
  "$defs": {
    "lease": {
      "type": "object",
      "required": ["pin", "status"],
      "additionalProperties": false,
      "properties": {
        "pin": { "$ref": "#/$defs/pin" },
        "status": { "type": "string", "minLength": 1 },
        "endpoint": { "$ref": "#/$defs/endpoint" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "expires_at": { "type": "string" }
      }
    },
    "endpoint": {
      "type": "object",
      "required": ["host", "port", "database", "role"],
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "database": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "sslmode": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "pin": {
      "type": "object",
      "required": ["schema_version", "provider", "project", "parent_branch", "branch", "branch_id", "database", "role", "created_by"],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "const": "scenery.db.branch.v1" },
        "provider": { "const": "sqlite" },
        "project": { "type": "string", "minLength": 1 },
        "parent_branch": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 },
        "branch_id": { "type": "string", "minLength": 1 },
        "database": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "session_id": { "type": "string" },
        "worktree_root": { "type": "string" },
        "created_by": { "const": "scenery" },
        "ttl": { "type": "string" }
      }
    }
  }
}
