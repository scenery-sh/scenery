{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.config.v1.schema.json",
  "title": "scenery.config.v1",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "build": {
      "$ref": "#/$defs/build"
    },
    "proxy": {
      "type": "object",
      "description": "Local proxy and dev route configuration. The removed legacy proxy host key is intentionally unsupported; use dev session routes, api_host, console_host, and frontends instead.",
      "properties": {
        "workspace": { "type": "string" },
        "route_base_domain": { "type": "string" },
        "api_host": { "type": "string" },
        "console_host": { "type": "string" },
        "frontends": {
          "type": ["object", "null"],
          "additionalProperties": { "$ref": "#/$defs/frontend" }
        }
      },
      "additionalProperties": false
    },
    "watch": {
      "type": "object",
      "description": "Scenery-owned dev watcher configuration for app-root-relative paths.",
      "properties": {
        "ignore": {
          "type": ["array", "null"],
          "description": "App-root-relative exclusion patterns for scenery up. Directory patterns such as reference/ skip the subtree without affecting Git tracking.",
          "items": {
            "type": "string",
            "minLength": 1,
            "not": {
              "anyOf": [
                { "pattern": "^/" },
                { "pattern": "^!" },
                { "pattern": "(^|/)\\.\\.(/|$)" }
              ]
            }
          }
        }
      },
      "additionalProperties": false
    },
    "dev": {
      "type": "object",
      "properties": {
        "services": {
          "type": ["object", "null"],
          "additionalProperties": { "$ref": "#/$defs/devService" }
        },
        "setup": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        },
        "routing": {
          "type": "object",
          "description": "Browser-facing local dev routing. The default mode is path, which assigns one stable localhost port per app root.",
          "properties": {
            "mode": { "type": "string", "enum": ["", "path", "host"] },
            "port": { "type": "integer", "minimum": 0, "maximum": 65535 },
            "port_start": { "type": "integer", "minimum": 0, "maximum": 65535 },
            "port_end": { "type": "integer", "minimum": 0, "maximum": 65535 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "deploy": {
      "$ref": "#/$defs/deploy"
    },
    "storage": {
      "$ref": "#/$defs/storage"
    },
    "generators": {
      "type": "object",
      "properties": {
        "clients": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/clientGenerator" }
        },
        "sqlc": { "$ref": "#/$defs/sqlcGenerator" }
      },
      "additionalProperties": false
    },
    "database": {
      "type": "object",
      "properties": {
        "url_env": { "type": "string", "description": "App-level Postgres database URL environment variable. Defaults to DATABASE_URL." },
        "apply": { "$ref": "#/$defs/databaseApply" },
        "seed": { "$ref": "#/$defs/databaseSeed" }
      },
      "additionalProperties": false
    },
    "tasks": {
      "type": ["object", "null"],
      "additionalProperties": { "$ref": "#/$defs/task" }
    },
    "validation": {
      "type": "object",
      "properties": {
        "default": { "type": "string" },
        "profiles": {
          "type": ["object", "null"],
          "additionalProperties": { "$ref": "#/$defs/validationProfile" }
        }
      },
      "additionalProperties": false
    },
    "auth": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "database_url_env": { "type": "string" },
        "jwt_secret_env": { "type": "string" },
        "refresh_cookie_name": { "type": "string" },
        "auth_cookie_domain_env": { "type": "string" },
        "public_app_url_env": { "type": "string" },
        "api_base_url_env": { "type": "string" },
        "email_from_env": { "type": "string" },
        "auto_bootstrap_database": { "type": "boolean" },
        "google_oauth": { "$ref": "#/$defs/authGoogleOAuth" },
        "dev_bootstrap": { "$ref": "#/$defs/authDevBootstrap" }
      },
      "additionalProperties": false
    },
    "observability": {
      "type": "object",
      "properties": {
        "logs": { "$ref": "#/$defs/endpointFilter" },
        "tracing": { "$ref": "#/$defs/endpointFilter" }
      },
      "additionalProperties": false
    }
  },
  "anyOf": [
    { "required": ["name"] },
    { "required": ["id"] }
  ],
  "additionalProperties": false,
  "$defs": {
    "build": {
      "type": "object",
      "description": "Scenery-owned Go build configuration for the generated app runtime.",
      "properties": {
        "go_flags": {
          "type": ["array", "null"],
          "description": "Literal argv entries passed to Scenery-owned go build and generated-workspace go test invocations. Use one array item per argument, for example [\"-tags=roofmapnet_native\"].",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "endpointFilter": {
      "type": "object",
      "properties": {
        "include_endpoints": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        },
        "exclude_endpoints": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "frontend": {
      "type": "object",
      "properties": {
        "host": { "type": "string" },
        "root": { "type": "string" },
        "upstream": { "type": "string" },
        "allow_shared_upstream": { "type": "boolean" }
      },
      "required": ["host"],
      "additionalProperties": false
    },
    "devService": {
      "type": "object",
      "properties": {
        "env": {
          "type": ["object", "null"],
          "description": "Reserved service environment metadata. Database services are kind-less in plan 0097.",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "deploy": {
      "type": "object",
      "description": "Beta public deploy configuration. One app may claim one public domain; deploy.root optionally names the service that owns / on that domain.",
      "properties": {
        "domain": {
          "type": "string",
          "description": "Lowercase public FQDN claimed by scenery deploy enable. Must not be localhost, an IP address, or the local route base domain.",
          "pattern": "^(?=.{1,253}$)([a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)+[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$"
        },
        "root": {
          "type": "string",
          "description": "Optional public / owner: api or a configured frontend name."
        }
      },
      "additionalProperties": false
    },
    "storage": {
      "type": "object",
      "description": "Beta Scenery-owned durable object/file storage capability.",
      "properties": {
        "cell_id": { "type": "string", "pattern": "^[a-z0-9._-]+$" },
        "share": { "type": "string", "enum": ["", "worktree"] },
        "default": { "type": "string" },
        "stores": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/storageStore" },
          "minProperties": 1
        }
      },
      "required": ["stores"],
      "additionalProperties": false
    },
    "storageStore": {
      "type": "object",
      "properties": {
        "kind": { "type": "string", "enum": ["", "local"], "description": "Storage backend kind. Empty defaults to local. The local backend is a Scenery-owned directory tree with atomic writes, checked fsync, and sidecar metadata; replicate offsite with rclone/restic for durability." },
        "access": { "type": "string", "enum": ["", "auth", "private"] },
        "tenant_scoped": { "type": "boolean" },
        "max_object_bytes": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "clientGenerator": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string", "enum": ["", "typescript-client"] },
        "target": { "type": "string" },
        "lang": { "type": "string", "enum": ["", "typescript", "ts"] },
        "output": { "type": "string" }
      },
      "required": ["output"],
      "additionalProperties": false
    },
    "sqlcGenerator": {
      "type": "object",
      "properties": {
        "provider": { "type": "string", "enum": ["", "sqlc"] },
        "config": { "type": "string" },
        "dev_url": { "type": "string" },
        "schemas": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/sqlcGeneratorSchema" }
        }
      },
      "additionalProperties": false
    },
    "sqlcGeneratorSchema": {
      "type": "object",
      "properties": {
        "sqlc_schema": { "type": "string" },
        "atlas_schema": { "type": "string" },
        "atlas_source": { "type": "string" },
        "atlas_dev_url": { "type": "string" }
      },
      "required": ["sqlc_schema"],
      "additionalProperties": false
    },
    "databaseApply": {
      "type": "object",
      "properties": {
        "command": { "type": "string" },
        "cwd": { "type": "string" },
        "env": {
          "type": ["object", "null"],
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "databaseSeed": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether scenery discovers and applies SERVICE/db/seed.sql and generated seed files. Defaults to true."
        }
      },
      "additionalProperties": false
    },
    "task": {
      "type": "object",
      "properties": {
        "cwd": { "type": "string" },
        "run": { "type": "string" },
        "steps": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        },
        "env": {
          "type": ["object", "null"],
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "validationProfile": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "cost": { "type": "string", "enum": ["", "low", "medium", "high"] },
        "paths": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        },
        "steps": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        },
        "env": {
          "type": ["object", "null"],
          "additionalProperties": { "type": "string" }
        },
        "artifacts": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "authGoogleOAuth": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "client_id_env": { "type": "string" },
        "client_secret_env": { "type": "string" }
      },
      "additionalProperties": false
    },
    "authDevBootstrap": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "default_user_email": { "type": "string" },
        "default_user_id": { "type": "string" },
        "default_tenant_id": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
