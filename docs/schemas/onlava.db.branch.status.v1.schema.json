{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.db.branch.status.v1.schema.json",
  "title": "onlava db branch status",
  "type": "object",
  "required": ["schema_version", "ok", "app", "provider", "status", "pin_path", "database_url_env", "psql_command", "reset_command"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "onlava.db.branch.status.v1" },
    "ok": { "type": "boolean" },
    "app": { "type": "object" },
    "provider": { "const": "neon-self-hosted" },
    "status": { "type": "string", "enum": ["unpinned", "pinned"] },
    "backend_status": { "type": "string", "enum": ["none", "pending", "ready", "missing", "expired", "protected", "unknown"] },
    "backend_message": { "type": "string" },
    "connection": { "$ref": "#/$defs/endpoint" },
    "pin_path": { "type": "string" },
    "pin": { "$ref": "#/$defs/pin" },
    "database_url_env": { "type": "string" },
    "psql_command": { "type": "string" },
    "reset_command": { "type": "string" },
    "message": { "type": "string" }
  },
  "$defs": {
    "pin": {
      "type": "object",
      "required": ["schema_version", "provider", "project", "parent_branch", "branch", "branch_id", "database", "role", "created_by"],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "const": "onlava.db.branch.v1" },
        "provider": { "const": "neon-self-hosted" },
        "project": { "type": "string", "minLength": 1 },
        "parent_branch": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 },
        "branch_id": { "type": "string", "minLength": 1 },
        "database": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "session_id": { "type": "string" },
        "worktree_root": { "type": "string" },
        "created_by": { "const": "onlava" },
        "ttl": { "type": "string" }
      }
    },
    "endpoint": {
      "type": "object",
      "required": ["host", "port", "database", "role"],
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "database": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "sslmode": { "type": "string" },
        "source": { "type": "string" }
      }
    }
  }
}
