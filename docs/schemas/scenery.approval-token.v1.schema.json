{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.approval-token.v1.schema.json",
  "title": "Scenery detached approval token",
  "type": "object",
  "required": ["plan_id", "caller", "risk_scopes", "expires_at", "signature"],
  "properties": {
    "plan_id": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "caller": { "type": "string", "minLength": 1 },
    "risk_scopes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "expires_at": { "type": "string", "format": "date-time" },
    "signature": { "type": "string", "pattern": "^ed25519:[^:\\s]+:[A-Za-z0-9+/]+={0,2}$" }
  },
  "additionalProperties": false
}
