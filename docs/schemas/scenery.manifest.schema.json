{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.manifest.schema.json",
  "title": "Scenery canonical manifest",
  "type": "object",
  "required": [
    "kind",
    "schema_revision",
    "spec_revision",
    "diagnostic_catalog",
    "producer",
    "application",
    "contract_revision",
    "resources",
    "source_map",
    "diagnostics"
  ],
  "properties": {
    "kind": {
      "const": "scenery.manifest"
    },
    "schema_revision": {
      "const": "sha256:d5b3c19523c452c5fafe25bceac20c42ab1d6de2d285a11615c7d24f21c2c3c7"
    },
    "spec_revision": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "producer": {
      "type": "object"
    },
    "diagnostic_catalog": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "application": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "contract_revision": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "address",
          "kind",
          "name",
          "module",
          "spec",
          "origin"
        ],
        "properties": {
          "address": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "pattern": "^scenery\\.[a-z][a-z0-9-]*$"
          },
          "name": {
            "type": "string"
          },
          "module": {
            "type": "string"
          },
          "spec": {
            "type": "object"
          },
          "origin": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "source_map": {
      "type": "object"
    },
    "diagnostics": {
      "type": "array"
    }
  },
  "additionalProperties": false
}
