{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.validation.graph.v1.schema.json",
  "title": "onlava.validation.graph.v1",
  "type": "object",
  "required": ["schema_version", "app", "profile", "nodes", "edges"],
  "properties": {
    "schema_version": { "const": "onlava.validation.graph.v1" },
    "app": { "type": "object", "additionalProperties": true },
    "profile": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "kind"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "kind": { "type": "string" },
          "source": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "kind"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "kind": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "diagnostics": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    }
  },
  "additionalProperties": false
}
