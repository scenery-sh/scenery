{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.inspect.routes.v1.schema.json",
  "title": "scenery.inspect.routes.v1",
  "type": "object",
  "required": ["schema_version", "app", "routes"],
  "properties": {
    "schema_version": { "const": "scenery.inspect.routes.v1" },
    "app": { "$ref": "#/$defs/appRef" },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "service", "endpoint", "package", "file", "access", "raw", "path", "methods", "has_payload", "wire"],
        "properties": {
          "id": { "type": "string" },
          "service": { "type": "string" },
          "endpoint": { "type": "string" },
          "package": { "type": "string" },
          "file": { "type": "string" },
          "access": { "type": "string", "enum": ["public", "auth", "private"] },
          "raw": { "type": "boolean" },
          "path": { "type": "string" },
          "methods": {
            "type": "array",
            "items": { "type": "string" }
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "receiver": { "type": "string" },
          "generated": { "type": "boolean" },
          "has_payload": { "type": "boolean" },
          "wire": { "$ref": "#/$defs/wireInfo" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "appRef": {
      "type": "object",
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" },
        "module_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "wireInfo": {
      "type": "object",
      "required": ["available"],
      "properties": {
        "available": { "type": "boolean" },
        "unsupported_reason": { "type": "string" },
        "schema_hash": { "type": "string" },
        "path": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
