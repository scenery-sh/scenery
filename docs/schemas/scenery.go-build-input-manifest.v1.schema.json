{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.go-build-input-manifest.v1.schema.json",
  "title": "Scenery Go Build Input Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "target", "entries", "digest"],
  "properties": {
    "api_version": { "const": "scenery.go-build-input-manifest/v1" },
    "target": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["identity", "digest"],
        "properties": {
          "identity": { "type": "string", "minLength": 1 },
          "digest": { "$ref": "#/$defs/digest" }
        }
      }
    },
    "digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
