{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.inspect.services.v1.schema.json",
  "title": "onlava.inspect.services.v1",
  "type": "object",
  "required": ["schema_version", "app", "services"],
  "properties": {
    "schema_version": { "const": "onlava.inspect.services.v1" },
    "app": { "$ref": "#/$defs/appRef" },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "root_rel_dir", "root_abs_dir", "package_dirs", "endpoints", "middleware"],
        "properties": {
          "name": { "type": "string" },
          "root_rel_dir": { "type": "string" },
          "root_abs_dir": { "type": "string" },
          "package_dirs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "endpoints": {
            "type": "array",
            "items": { "type": "string" }
          },
          "middleware": {
            "type": "array",
            "items": { "type": "string" }
          },
          "service_struct": {
            "type": "object",
            "required": ["type_name"],
            "properties": {
              "type_name": { "type": "string" },
              "init_func": { "type": "string" },
              "shutdown": { "type": "string" }
            },
            "additionalProperties": false
          },
          "auth_handler": {
            "type": "object",
            "required": ["name", "package"],
            "properties": {
              "name": { "type": "string" },
              "package": { "type": "string" },
              "receiver": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "appRef": {
      "type": "object",
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" },
        "module_path": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
