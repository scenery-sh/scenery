{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.logs.event.v1.schema.json",
  "title": "onlava.logs.event.v1",
  "description": "Schema for `onlava logs --jsonl` and `onlava logs --json` output lines.",
  "type": "object",
  "required": ["schema_version", "app", "id", "pid", "stream", "output", "created_at"],
  "properties": {
    "schema_version": { "const": "onlava.logs.event.v1" },
    "app": {
      "type": "object",
      "required": ["name", "root"],
      "properties": {
        "name": { "type": "string" },
        "root": { "type": "string" }
      },
      "additionalProperties": false
    },
    "id": { "type": "integer", "minimum": 1 },
    "pid": { "type": "string" },
    "stream": { "type": "string", "enum": ["stdout", "stderr"] },
    "output": { "type": "string" },
    "created_at": { "type": "string" }
  },
  "additionalProperties": false
}
