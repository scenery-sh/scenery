{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.inspect.docs.schema.json",
  "title": "scenery.inspect.docs",
  "type": "object",
  "required": [
    "kind",
    "schema_revision",
    "repo",
    "summary",
    "agents",
    "documents",
    "plans",
    "tech_debt"
  ],
  "properties": {
    "kind": {
      "const": "scenery.inspect.docs"
    },
    "schema_revision": {
      "const": "sha256:a13fe6effd00df3811d1cf3d163c9898503f09f7adae939b075b64eb9789996a"
    },
    "repo": {
      "type": "object",
      "required": [
        "root",
        "module_path",
        "go_mod_path"
      ],
      "properties": {
        "root": {
          "type": "string"
        },
        "module_path": {
          "const": "scenery.sh"
        },
        "go_mod_path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "document_count",
        "missing_count",
        "review_due_count",
        "stale_count",
        "agent_scope_count",
        "stale_child_index_entry_count",
        "missing_child_index_entry_count",
        "quality"
      ],
      "properties": {
        "document_count": {
          "type": "integer"
        },
        "missing_count": {
          "type": "integer"
        },
        "review_due_count": {
          "type": "integer"
        },
        "stale_count": {
          "type": "integer"
        },
        "agent_scope_count": {
          "type": "integer"
        },
        "stale_child_index_entry_count": {
          "type": "integer"
        },
        "missing_child_index_entry_count": {
          "type": "integer"
        },
        "quality": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        }
      },
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "agents": {
      "type": "object",
      "required": [
        "scopes",
        "child_index_path",
        "child_index_entries",
        "stale_child_index_entries",
        "missing_child_index_entries"
      ],
      "properties": {
        "scopes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/agent_scope"
          }
        },
        "child_index_path": {
          "type": "string"
        },
        "child_index_entries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stale_child_index_entries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_child_index_entries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "documents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/document"
      }
    },
    "plans": {
      "type": "object",
      "required": [
        "active",
        "completed"
      ],
      "properties": {
        "active": {
          "$ref": "#/$defs/artifact"
        },
        "completed": {
          "$ref": "#/$defs/artifact"
        }
      },
      "additionalProperties": false
    },
    "tech_debt": {
      "$ref": "#/$defs/artifact"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "artifact": {
      "type": "object",
      "required": [
        "path",
        "exists"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "agent_scope": {
      "type": "object",
      "required": [
        "path",
        "scope"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "document": {
      "type": "object",
      "required": [
        "path",
        "title",
        "owner",
        "status",
        "quality",
        "freshness",
        "last_reviewed",
        "review_after",
        "summary",
        "tags",
        "exists",
        "review_due",
        "stale"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "quality": {
          "type": "string"
        },
        "freshness": {
          "type": "string"
        },
        "last_reviewed": {
          "type": "string"
        },
        "review_after": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "schema_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exists": {
          "type": "boolean"
        },
        "size_bytes": {
          "type": "integer"
        },
        "modified_at": {
          "type": "string"
        },
        "review_due": {
          "type": "boolean"
        },
        "stale": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  }
}
