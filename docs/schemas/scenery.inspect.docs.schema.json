{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.inspect.docs.schema.json",
  "title": "scenery.inspect.docs",
  "type": "object",
  "required": [
    "kind",
    "schema_revision",
    "repo",
    "query",
    "summary",
    "agents",
    "documents"
  ],
  "properties": {
    "kind": {
      "const": "scenery.inspect.docs"
    },
    "schema_revision": {
      "const": "sha256:cef606ca6894f7126a86ead96efcc6c7eacababa97be5c68b19db7514e734112"
    },
    "repo": {
      "type": "object",
      "required": [
        "root",
        "module_path",
        "go_mod_path"
      ],
      "properties": {
        "root": {
          "type": "string"
        },
        "module_path": {
          "const": "scenery.sh"
        },
        "go_mod_path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "query": {
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "enum": [
            "summary",
            "all",
            "filter",
            "path"
          ]
        },
        "for_path": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "status": {
          "enum": [
            "active",
            "reference",
            "completed",
            "deprecated"
          ]
        },
        "review_due": {
          "type": "boolean"
        },
        "all": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "document_count",
        "selected_document_count",
        "missing_count",
        "review_due_count",
        "stale_count",
        "agent_scope_count",
        "stale_child_index_entry_count",
        "missing_child_index_entry_count",
        "quality"
      ],
      "properties": {
        "document_count": {
          "type": "integer"
        },
        "selected_document_count": {
          "type": "integer"
        },
        "missing_count": {
          "type": "integer"
        },
        "review_due_count": {
          "type": "integer",
          "description": "Living documents whose scheduled review date has arrived; completed numbered ExecPlans are excluded."
        },
        "stale_count": {
          "type": "integer"
        },
        "agent_scope_count": {
          "type": "integer"
        },
        "stale_child_index_entry_count": {
          "type": "integer"
        },
        "missing_child_index_entry_count": {
          "type": "integer"
        },
        "quality": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        }
      },
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "agents": {
      "type": "object",
      "required": [
        "scopes"
      ],
      "properties": {
        "scopes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/agent_scope"
          }
        },
        "child_index_path": {
          "type": "string"
        },
        "child_index_entries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stale_child_index_entries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_child_index_entries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "documents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/document"
      }
    },
    "verification_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "plans": {
      "type": "object",
      "required": [
        "active",
        "completed"
      ],
      "properties": {
        "active": {
          "$ref": "#/$defs/artifact"
        },
        "completed": {
          "$ref": "#/$defs/artifact"
        }
      },
      "additionalProperties": false
    },
    "tech_debt": {
      "$ref": "#/$defs/artifact"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "artifact": {
      "type": "object",
      "required": [
        "path",
        "exists"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "agent_scope": {
      "type": "object",
      "required": [
        "path",
        "scope"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "document": {
      "type": "object",
      "required": [
        "path",
        "title",
        "owner",
        "status",
        "quality",
        "freshness",
        "last_reviewed",
        "review_after",
        "summary",
        "tags",
        "exists",
        "review_due",
        "stale"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "quality": {
          "type": "string"
        },
        "freshness": {
          "type": "string"
        },
        "last_reviewed": {
          "type": "string"
        },
        "review_after": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "schema_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exists": {
          "type": "boolean"
        },
        "size_bytes": {
          "type": "integer"
        },
        "modified_at": {
          "type": "string"
        },
        "review_due": {
          "type": "boolean",
          "description": "Whether this living document has reached its scheduled review date. Always false for a completed numbered ExecPlan."
        },
        "stale": {
          "type": "boolean"
        },
        "role": {
          "enum": [
            "direct",
            "architecture",
            "contract",
            "active_execplan",
            "schema"
          ]
        },
        "reason": {
          "type": "string"
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/section"
          }
        }
      },
      "additionalProperties": false
    },
    "section": {
      "type": "object",
      "required": [
        "heading",
        "anchor",
        "start_line",
        "end_line"
      ],
      "properties": {
        "heading": {
          "type": "string"
        },
        "anchor": {
          "type": "string"
        },
        "start_line": {
          "type": "integer",
          "minimum": 1
        },
        "end_line": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    }
  }
}
