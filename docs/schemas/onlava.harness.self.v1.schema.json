{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.harness.self.v1.schema.json",
  "title": "Onlava self harness result",
  "type": "object",
  "required": ["schema_version", "ok", "generated_at", "repo", "knowledge", "steps", "artifacts"],
  "properties": {
    "schema_version": {
      "const": "onlava.harness.self.v1"
    },
    "ok": {
      "type": "boolean"
    },
    "generated_at": {
      "type": "string"
    },
    "repo": {
      "type": "object",
      "required": ["root", "module_path", "go_mod_path"],
      "properties": {
        "root": { "type": "string" },
        "module_path": { "const": "onlava.com" },
        "go_mod_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "knowledge": {
      "type": "object",
      "required": ["entrypoints", "schemas"],
      "properties": {
        "entrypoints": {
          "type": "array",
          "items": { "$ref": "#/$defs/knowledge_file" }
        },
        "schemas": {
          "type": "array",
          "items": { "$ref": "#/$defs/knowledge_file" }
        }
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/$defs/step" }
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "wrote": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "knowledge_file": {
      "type": "object",
      "required": ["path", "exists"],
      "properties": {
        "path": { "type": "string" },
        "exists": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "step": {
      "type": "object",
      "required": ["name", "command", "ok", "duration_ms"],
      "properties": {
        "name": { "type": "string" },
        "command": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ok": { "type": "boolean" },
        "duration_ms": { "type": "integer" },
        "summary": {
          "type": "object",
          "additionalProperties": true
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "error": { "type": "string" },
        "output_tail": { "type": "string" }
      },
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": ["name", "path", "exists"],
      "properties": {
        "name": { "type": "string" },
        "path": { "type": "string" },
        "schema_version": { "type": "string" },
        "exists": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
