{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.db.branch.registry.v2.schema.json",
  "title": "scenery SQLite branch lease registry",
  "type": "object",
  "required": ["schema_version", "provider", "leases"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "scenery.db.branch.registry.v2" },
    "provider": { "const": "sqlite" },
    "updated_at": { "type": "string" },
    "leases": {
      "type": "array",
      "items": { "$ref": "#/$defs/lease" }
    }
  },
  "$defs": {
    "lease": {
      "type": "object",
      "required": ["pin", "status"],
      "additionalProperties": false,
      "properties": {
        "pin": { "$ref": "#/$defs/pin" },
        "status": { "type": "string", "enum": ["pending", "ready", "missing", "expired"] },
        "endpoint": { "$ref": "#/$defs/endpoint" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "expires_at": { "type": "string" }
      }
    },
    "pin": {
      "type": "object",
      "required": ["schema_version", "provider", "project", "parent_branch", "branch", "branch_id", "database", "role", "created_by"],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "const": "scenery.db.branch.v1" },
        "provider": { "const": "sqlite" },
        "project": { "type": "string", "minLength": 1 },
        "parent_branch": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 },
        "branch_id": { "type": "string", "minLength": 1 },
        "database": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "session_id": { "type": "string" },
        "worktree_root": { "type": "string" },
        "created_by": { "const": "scenery" },
        "ttl": { "type": "string" }
      }
    },
    "endpoint": {
      "type": "object",
      "required": ["host", "port", "database", "role"],
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "database": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "sslmode": { "type": "string" },
        "source": { "type": "string" }
      }
    }
  }
}
