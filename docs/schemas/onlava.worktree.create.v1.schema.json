{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.worktree.create.v1.schema.json",
  "title": "onlava worktree create result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "ok", "name", "path", "branch", "next_command"],
  "properties": {
    "schema_version": { "const": "onlava.worktree.create.v1" },
    "ok": { "type": "boolean" },
    "name": { "type": "string" },
    "path": { "type": "string" },
    "branch": { "type": "string" },
    "from": { "type": "string" },
    "db_pin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "provider", "project", "parent_branch", "branch", "branch_id", "database", "role", "created_by"],
      "properties": {
        "schema_version": { "const": "onlava.db.branch.v1" },
        "provider": { "const": "neon-self-hosted" },
        "project": { "type": "string" },
        "parent_branch": { "type": "string" },
        "branch": { "type": "string" },
        "branch_id": { "type": "string" },
        "database": { "type": "string" },
        "role": { "type": "string" },
        "session_id": { "type": "string" },
        "worktree_root": { "type": "string" },
        "created_by": { "type": "string" },
        "ttl": { "type": "string" }
      }
    },
    "next_command": { "type": "string" },
    "message": { "type": "string" }
  }
}
