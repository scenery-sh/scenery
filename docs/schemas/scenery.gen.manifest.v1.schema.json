{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.gen.manifest.v1.schema.json",
  "title": "scenery.gen.manifest.v1",
  "type": "object",
  "required": ["schema_version", "app", "counts", "artifacts", "schemas", "hashes"],
  "properties": {
    "schema_version": { "const": "scenery.gen.manifest.v1" },
    "app": {
      "type": "object",
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" },
        "module_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "counts": {
      "type": "object",
      "required": ["packages", "services", "endpoints", "middleware", "auth_handler", "runtime_declarations"],
      "properties": {
        "packages": { "type": "integer", "minimum": 0 },
        "services": { "type": "integer", "minimum": 0 },
        "endpoints": { "type": "integer", "minimum": 0 },
        "middleware": { "type": "integer", "minimum": 0 },
        "auth_handler": { "type": "integer", "minimum": 0 },
        "runtime_declarations": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "required": ["app", "routes", "services", "endpoints", "models", "views", "wire_capabilities", "build_latest"],
      "properties": {
        "app": { "type": "string" },
        "routes": { "type": "string" },
        "services": { "type": "string" },
        "endpoints": { "type": "string" },
        "models": { "type": "string" },
        "views": { "type": "string" },
        "wire_capabilities": { "type": "string" },
        "build_latest": { "type": "string" }
      },
      "additionalProperties": false
    },
    "schemas": {
      "type": "object",
      "required": ["app", "routes", "services", "endpoints", "models", "views", "wire_capabilities", "build_latest"],
      "properties": {
        "app": { "type": "string" },
        "routes": { "type": "string" },
        "services": { "type": "string" },
        "endpoints": { "type": "string" },
        "models": { "type": "string" },
        "views": { "type": "string" },
        "wire_capabilities": { "type": "string" },
        "build_latest": { "type": "string" }
      },
      "additionalProperties": false
    },
    "hashes": {
      "type": "object",
      "required": ["app", "routes", "services", "endpoints", "models", "views", "wire_capabilities"],
      "properties": {
        "app": { "type": "string" },
        "routes": { "type": "string" },
        "services": { "type": "string" },
        "endpoints": { "type": "string" },
        "models": { "type": "string" },
        "views": { "type": "string" },
        "wire_capabilities": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
