{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.deploy.registry.v1.schema.json",
  "title": "scenery deploy registry",
  "type": "object",
  "required": ["schema_version", "targets"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "scenery.deploy.registry.v1" },
    "acme_email": { "type": "string" },
    "acme_ca": { "enum": ["production", "staging"] },
    "targets": {
      "type": "array",
      "items": { "$ref": "#/$defs/target" }
    }
  },
  "$defs": {
    "target": {
      "type": "object",
      "required": ["domain", "app_root", "enabled", "created_at", "updated_at"],
      "additionalProperties": false,
      "properties": {
        "domain": { "type": "string", "minLength": 1 },
        "app_root": { "type": "string", "minLength": 1 },
        "root_service": { "type": "string" },
        "enabled": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
