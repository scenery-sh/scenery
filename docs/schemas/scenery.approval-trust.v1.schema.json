{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.approval-trust.v1.schema.json",
  "title": "Scenery app-local approval trust store",
  "type": "object",
  "required": ["api_version", "keys"],
  "properties": {
    "api_version": { "const": "scenery.approval-trust.v1" },
    "keys": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "type": "string", "minLength": 1, "pattern": "^[^:\\s]+$" },
      "additionalProperties": {
        "type": "string",
        "description": "Raw 32-byte Ed25519 public key in padded or unpadded standard base64."
      }
    }
  },
  "additionalProperties": false
}
