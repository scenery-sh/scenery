{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.db.list.v3.schema.json",
  "title": "scenery db list",
  "type": "object",
  "required": ["schema_version", "database"],
  "properties": {
    "schema_version": { "const": "scenery.db.list.v3" },
    "database": {
      "type": "object",
      "required": ["name", "url", "source", "schemas"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "enum": ["managed", "external"] },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "schemas": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["service", "schema"],
            "properties": {
              "service": { "type": "string", "minLength": 1 },
              "schema": { "type": "string", "minLength": 1 },
              "url": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
