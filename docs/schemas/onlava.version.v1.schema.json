{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.version.v1.schema.json",
  "title": "Onlava version",
  "type": "object",
  "required": ["schema_version", "version", "go_version"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "onlava.version.v1"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "commit": {
      "type": "string"
    },
    "built_at": {
      "type": "string"
    },
    "go_version": {
      "type": "string",
      "minLength": 1
    },
    "module_version": {
      "type": "string"
    }
  }
}
