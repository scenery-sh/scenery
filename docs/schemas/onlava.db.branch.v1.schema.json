{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.db.branch.v1.schema.json",
  "title": "onlava.db.branch.v1",
  "type": "object",
  "required": ["schema_version", "provider", "project", "parent_branch", "branch", "branch_id", "database", "role", "created_by"],
  "properties": {
    "schema_version": { "const": "onlava.db.branch.v1" },
    "provider": { "const": "neon-self-hosted" },
    "project": { "type": "string", "minLength": 1 },
    "parent_branch": { "type": "string", "minLength": 1 },
    "branch": { "type": "string", "minLength": 1 },
    "branch_id": { "type": "string", "pattern": "^br-local-[a-f0-9]+$" },
    "database": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string" },
    "worktree_root": { "type": "string" },
    "created_by": { "const": "onlava" },
    "ttl": { "type": "string" },
    "database_name": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
