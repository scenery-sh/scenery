{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.agent.cleanup.schema.json",
  "title": "scenery.agent.cleanup",
  "type": "object",
  "required": [
    "kind",
    "schema_revision",
    "home",
    "state_present",
    "state_removed"
  ],
  "properties": {
    "kind": {
      "const": "scenery.agent.cleanup"
    },
    "schema_revision": {
      "const": "sha256:5f295f5a076621018f2fef478b19d82d4c8d248647ab81af362224d9664e04e1"
    },
    "home": {
      "type": "string"
    },
    "state_present": {
      "type": "boolean"
    },
    "state_removed": {
      "type": "boolean"
    },
    "matched_pids": {
      "type": "array",
      "items": {"type": "integer", "minimum": 1}
    },
    "stopped_pids": {
      "type": "array",
      "items": {"type": "integer", "minimum": 1}
    },
    "skipped_unverified_pids": {
      "type": "array",
      "items": {"type": "integer", "minimum": 1}
    }
  },
  "additionalProperties": false
}
