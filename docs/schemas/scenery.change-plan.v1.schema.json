{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.change-plan.v1.schema.json",
  "title": "Scenery semantic change plan",
  "type": "object",
  "required": ["api_version", "plan_id", "application", "base_workspace_revision", "base_contract_revision", "predicted_workspace_revision", "predicted_contract_revision", "implementation_revision_status", "deployment_revision_status", "caller", "capabilities", "operations_digest", "operations", "semantic_diff", "affected_resources", "diagnostics", "source_edits", "formatting_effects", "required_approvals", "required_capabilities", "risk_records", "expires_at"],
  "properties": {
    "api_version": { "const": "scenery.change-plan/v1" },
    "plan_id": { "$ref": "#/$defs/revision" },
    "application": { "type": "string", "minLength": 1 },
    "base_workspace_revision": { "$ref": "#/$defs/revision" },
    "base_contract_revision": { "oneOf": [{ "$ref": "#/$defs/revision" }, { "type": "null" }] },
    "predicted_workspace_revision": { "$ref": "#/$defs/revision" },
    "predicted_contract_revision": { "$ref": "#/$defs/revision" },
    "implementation_revision_status": { "type": "string", "minLength": 1 },
    "deployment_revision_status": { "type": "string", "minLength": 1 },
    "caller": { "type": "string", "minLength": 1 },
    "capabilities": { "$ref": "#/$defs/string_list" },
    "operations_digest": { "$ref": "#/$defs/revision" },
    "operations": { "type": "array", "items": { "$ref": "#/$defs/operation" } },
    "semantic_diff": { "type": "object" },
    "affected_resources": { "$ref": "#/$defs/string_list" },
    "diagnostics": { "type": "array", "items": { "type": "object" } },
    "source_edits": { "type": "array", "items": { "$ref": "#/$defs/source_edit" } },
    "formatting_effects": { "$ref": "#/$defs/string_list" },
    "required_approvals": { "$ref": "#/$defs/string_list" },
    "required_capabilities": { "$ref": "#/$defs/string_list" },
    "risk_records": { "type": "array" },
    "expires_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "revision": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "string_list": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "operation": {
      "type": "object", "required": ["op", "address"],
      "properties": { "op": { "type": "string" }, "address": { "type": "string" }, "view": { "type": "string" }, "path": { "type": "string" }, "value": {}, "precondition": { "type": "object" } },
      "additionalProperties": false
    },
    "source_edit": {
      "type": "object", "required": ["path", "before_digest", "after", "before_exists", "after_exists"],
      "properties": { "path": { "type": "string" }, "before_digest": { "type": "string" }, "after": { "type": "string", "contentEncoding": "base64" }, "before_exists": { "type": "boolean" }, "after_exists": { "type": "boolean" }, "mode": { "type": "integer", "minimum": 0 } },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
