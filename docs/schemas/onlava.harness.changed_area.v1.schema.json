{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.harness.changed_area.v1.schema.json",
  "title": "onlava harness changed area report",
  "type": "object",
  "required": ["schema_version", "changed_files", "affected_packages", "recommended_commands", "relevant_docs", "risk_flags"],
  "properties": {
    "schema_version": {
      "const": "onlava.harness.changed_area.v1"
    },
    "changed_files": {
      "type": "array",
      "items": { "$ref": "#/$defs/changed_file" }
    },
    "affected_packages": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "relevant_docs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risk_flags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "changed_file": {
      "type": "object",
      "required": ["path", "status", "category"],
      "properties": {
        "path": { "type": "string" },
        "status": { "type": "string" },
        "category": { "type": "string" },
        "package": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
