{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.harness.ui.v1.schema.json",
  "title": "onlava UI harness result",
  "type": "object",
  "required": ["schema_version", "ok", "generated_at", "app", "dashboard_url", "routes", "artifacts"],
  "properties": {
    "schema_version": {
      "const": "onlava.harness.ui.v1"
    },
    "ok": {
      "type": "boolean"
    },
    "generated_at": {
      "type": "string"
    },
    "app": {
      "type": "object",
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" },
        "module_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "dashboard_url": {
      "type": "string"
    },
    "routes": {
      "type": "array",
      "items": { "$ref": "#/$defs/route" }
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence" }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "wrote": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "route": {
      "type": "object",
      "required": ["name", "url", "ok", "duration_ms", "markers"],
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "ok": { "type": "boolean" },
        "duration_ms": { "type": "integer" },
        "markers": {
          "type": "array",
          "items": { "$ref": "#/$defs/marker" }
        },
        "screenshot": { "type": "string" },
        "evidence": {
          "$ref": "#/$defs/evidence"
        },
        "console_errors": {
          "type": "array",
          "items": { "$ref": "#/$defs/console_error" }
        },
        "network_failures": {
          "type": "array",
          "items": { "$ref": "#/$defs/network_failure" }
        },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["schema_version", "duration_ms"],
      "properties": {
        "schema_version": { "const": "onlava.harness.artifact.v1" },
        "command": {
          "type": "array",
          "items": { "type": "string" }
        },
        "cwd": { "type": "string" },
        "started_at": { "type": "string" },
        "duration_ms": { "type": "integer" },
        "exit_code": { "type": "integer" },
        "stdout_tail": { "type": "string" },
        "stderr_tail": { "type": "string" },
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_artifact" }
        },
        "repro_command": { "type": "string" }
      },
      "additionalProperties": false
    },
    "evidence_artifact": {
      "type": "object",
      "required": ["name", "path"],
      "properties": {
        "name": { "type": "string" },
        "path": { "type": "string" },
        "schema_version": { "type": "string" }
      },
      "additionalProperties": false
    },
    "marker": {
      "type": "object",
      "required": ["selector", "count", "found"],
      "properties": {
        "selector": { "type": "string" },
        "count": { "type": "integer" },
        "found": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "console_error": {
      "type": "object",
      "required": ["level", "message"],
      "properties": {
        "route": { "type": "string" },
        "level": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "network_failure": {
      "type": "object",
      "required": ["error"],
      "properties": {
        "route": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": ["name", "path", "exists"],
      "properties": {
        "name": { "type": "string" },
        "path": { "type": "string" },
        "schema_version": { "type": "string" },
        "exists": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
