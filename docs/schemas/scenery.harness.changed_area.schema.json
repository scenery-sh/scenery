{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.harness.changed_area.schema.json",
  "title": "scenery harness changed area report",
  "type": "object",
  "required": [
    "kind",
    "schema_revision",
    "changed_files",
    "affected_packages",
    "validation_classes",
    "recommended_commands",
    "relevant_docs",
    "risk_flags"
  ],
  "properties": {
    "kind": {
      "const": "scenery.harness.changed_area"
    },
    "schema_revision": {
      "const": "sha256:5c5d834d0db2d94a819c3ffb50841d3cb61870c83cf0cd746107131cd7679106"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/changed_file"
      }
    },
    "ignored_files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/changed_file"
      }
    },
    "affected_packages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_classes": {
      "type": "array",
      "items": {
        "enum": [
          "documentation-only",
          "go-package",
          "cli-json-contract",
          "compiler-or-generator",
          "ui-catalog",
          "dashboard",
          "release-sensitive-or-runtime",
          "repository-fallback"
        ]
      },
      "uniqueItems": true
    },
    "recommended_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "relevant_docs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "changed_file": {
      "type": "object",
      "required": [
        "path",
        "status",
        "category"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "package": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
