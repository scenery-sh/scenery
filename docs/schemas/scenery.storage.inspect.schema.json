{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.storage.inspect.schema.json",
  "title": "scenery.storage.inspect",
  "type": "object",
  "required": [
    "kind",
    "schema_revision",
    "app",
    "storage",
    "stores"
  ],
  "properties": {
    "kind": {
      "const": "scenery.storage.inspect"
    },
    "schema_revision": {
      "const": "sha256:4765e31dc934ac88a1c8e84cc49da83e3863352a0056f6a756cca36c6e8972d4"
    },
    "app": {
      "type": "object",
      "required": [
        "name",
        "root",
        "config_path"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "root": {
          "type": "string"
        },
        "config_path": {
          "type": "string"
        },
        "module_path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "storage": {
      "type": "object",
      "required": [
        "configured",
        "readiness"
      ],
      "properties": {
        "configured": {
          "type": "boolean"
        },
        "storage_cell_id": {
          "type": "string"
        },
        "share": {
          "type": "string"
        },
        "default": {
          "type": "string"
        },
        "readiness": {
          "type": "string",
          "enum": [
            "not_configured",
            "configured",
            "ready",
            "error"
          ]
        },
        "runtime": {
          "type": "object",
          "required": [
            "exists"
          ],
          "properties": {
            "cell_root": {
              "type": "string"
            },
            "objects_dir": {
              "type": "string"
            },
            "exists": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "stores": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "kind",
          "access",
          "tenant_scoped",
          "object_count",
          "total_bytes"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "local"
            ]
          },
          "access": {
            "type": "string",
            "enum": [
              "auth",
              "private"
            ]
          },
          "tenant_scoped": {
            "type": "boolean"
          },
          "max_object_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "object_count": {
            "type": "integer",
            "minimum": 0
          },
          "total_bytes": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
