{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.inspect.endpoints.v1.schema.json",
  "title": "scenery.inspect.endpoints.v1",
  "type": "object",
  "required": ["schema_version", "app", "endpoints"],
  "properties": {
    "schema_version": { "const": "scenery.inspect.endpoints.v1" },
    "app": { "$ref": "#/$defs/appRef" },
    "endpoints": {
      "type": "array",
      "items": { "$ref": "#/$defs/endpoint" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "appRef": {
      "type": "object",
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" },
        "module_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "endpoint": {
      "type": "object",
      "required": ["id", "service", "endpoint", "access", "raw", "path", "methods", "has_payload"],
      "properties": {
        "id": { "type": "string" },
        "service": { "type": "string" },
        "endpoint": { "type": "string" },
        "access": { "type": "string", "enum": ["public", "auth", "private"] },
        "raw": { "type": "boolean" },
        "path": { "type": "string" },
        "methods": {
          "type": "array",
          "items": { "type": "string" }
        },
        "generated": { "type": "boolean" },
        "has_payload": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
