{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.runtime-bundle.v1.schema.json",
  "title": "Scenery Runtime Bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "artifact_kind",
    "application",
    "target",
    "contract_revision",
    "implementation_revision",
    "build_input_manifest",
    "resolved_go_target",
    "runtime_abi"
  ],
  "properties": {
    "api_version": { "const": "scenery.runtime-bundle/v1" },
    "artifact_kind": { "const": "go_runtime_bundle" },
    "application": { "type": "string", "minLength": 1 },
    "target": { "type": "string", "minLength": 1 },
    "contract_revision": { "$ref": "#/$defs/digest" },
    "implementation_revision": { "$ref": "#/$defs/digest" },
    "build_input_manifest": { "$ref": "scenery.go-build-input-manifest.v1.schema.json" },
    "resolved_go_target": { "type": "object" },
    "runtime_abi": { "const": "scenery.go-runtime/v1" }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
