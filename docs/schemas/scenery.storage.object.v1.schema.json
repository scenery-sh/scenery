{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.storage.object.v1.schema.json",
  "title": "scenery.storage.object.v1",
  "type": "object",
  "required": ["schema_version", "object"],
  "properties": {
    "schema_version": { "const": "scenery.storage.object.v1" },
    "object": {
      "type": "object",
      "required": ["store", "key", "size_bytes", "modified_at"],
      "properties": {
        "store": { "type": "string" },
        "key": { "type": "string" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "content_type": { "type": "string" },
        "etag": { "type": "string" },
        "sha256": { "type": "string" },
        "modified_at": { "type": "string", "format": "date-time" },
        "metadata": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
