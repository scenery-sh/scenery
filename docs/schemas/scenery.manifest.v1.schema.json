{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.manifest.v1.schema.json",
  "title": "Scenery edition-2027 canonical manifest",
  "type": "object",
  "required": ["api_version", "edition", "diagnostic_catalog", "application", "profiles", "contract_revision", "resources", "source_map", "diagnostics"],
  "properties": {
    "api_version": { "const": "scenery.manifest.v1" },
    "edition": { "const": "2027" },
    "diagnostic_catalog": { "const": "scenery.diagnostics.2027.v1" },
    "application": {
      "type": "object",
      "required": ["name", "version"],
      "properties": { "name": { "type": "string" }, "version": { "type": "string" } },
      "additionalProperties": false
    },
    "profiles": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "contract_revision": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["address", "kind", "name", "module", "spec", "origin"],
        "properties": {
          "address": { "type": "string" },
          "kind": { "type": "string" },
          "name": { "type": "string" },
          "module": { "type": "string" },
          "spec": { "type": "object" },
          "origin": { "type": "object" },
          "migration": { "type": "object" }
        },
        "additionalProperties": false
      }
    },
    "source_map": { "type": "object" },
    "diagnostics": { "type": "array" }
  },
  "additionalProperties": false
}
