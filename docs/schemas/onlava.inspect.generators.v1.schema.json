{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.inspect.generators.v1.schema.json",
  "title": "onlava.inspect.generators.v1",
  "type": "object",
  "required": ["schema_version", "app", "generators"],
  "properties": {
    "schema_version": { "const": "onlava.inspect.generators.v1" },
    "app": { "$ref": "#/$defs/appRef" },
    "generators": {
      "type": "array",
      "items": { "$ref": "#/$defs/generator" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "appRef": {
      "type": "object",
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" },
        "module_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "generator": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tool": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
