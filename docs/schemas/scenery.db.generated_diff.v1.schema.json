{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.db.generated_diff.v1.schema.json",
  "title": "scenery.db.generated_diff.v1",
  "description": "Schema for `scenery db diff --generated --json` responses.",
  "type": "object",
  "required": ["schema_version", "ok", "app", "drift", "generated"],
  "properties": {
    "schema_version": { "const": "scenery.db.generated_diff.v1" },
    "ok": { "type": "boolean" },
    "app": { "$ref": "#/$defs/appRef" },
    "drift": {
      "type": "array",
      "items": { "$ref": "#/$defs/drift" }
    },
    "generated": {
      "type": "array",
      "items": { "$ref": "#/$defs/generatedSchema" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "appRef": {
      "type": "object",
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" },
        "module_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "drift": {
      "type": "object",
      "required": ["service", "source_path", "generated_path", "message"],
      "properties": {
        "service": { "type": "string" },
        "source_path": { "type": "string" },
        "generated_path": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "generatedSchema": {
      "type": "object",
      "required": ["service", "source_path", "generated_path", "entities"],
      "properties": {
        "service": { "type": "string" },
        "source_path": { "type": "string" },
        "generated_path": { "type": "string" },
        "entities": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
