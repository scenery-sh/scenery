{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.inspect.generators.v1.schema.json",
  "title": "scenery.inspect.generators.v1",
  "type": "object",
  "required": ["schema_version", "app", "generators", "db_artifacts"],
  "properties": {
    "schema_version": { "const": "scenery.inspect.generators.v1" },
    "app": { "$ref": "#/$defs/appRef" },
    "generators": {
      "type": "array",
      "items": { "$ref": "#/$defs/generator" }
    },
    "db_artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/dbArtifact" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "appRef": {
      "type": "object",
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" },
        "module_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "generator": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tool": { "type": "string" }
      },
      "additionalProperties": false
    },
    "dbArtifact": {
      "type": "object",
      "required": ["service", "kind", "role", "path"],
      "properties": {
        "service": { "type": "string" },
        "engine": {
          "type": "string",
          "enum": ["sqlite", "postgres"]
        },
        "kind": {
          "type": "string",
          "enum": ["schema-source", "query", "generated-schema", "seed"]
        },
        "role": {
          "type": "string",
          "enum": ["schema", "query-generation-input", "generated-source", "initial-data"]
        },
        "path": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
