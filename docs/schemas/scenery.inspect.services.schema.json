{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.inspect.services.schema.json",
  "title": "scenery.inspect.services",
  "type": "object",
  "required": [
    "kind",
    "schema_revision",
    "app",
    "services"
  ],
  "properties": {
    "kind": {
      "const": "scenery.inspect.services"
    },
    "schema_revision": {
      "const": "sha256:eed0de0f1862bd98948f299b756a92df5f13532b1f1d71df5dd908cf33aa0c28"
    },
    "app": {
      "$ref": "#/$defs/appRef"
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "root_rel_dir",
          "root_abs_dir",
          "package_dirs",
          "endpoints",
          "middleware"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "root_rel_dir": {
            "type": "string"
          },
          "root_abs_dir": {
            "type": "string"
          },
          "package_dirs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "endpoints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "middleware": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "service_struct": {
            "type": "object",
            "required": [
              "type_name"
            ],
            "properties": {
              "type_name": {
                "type": "string"
              },
              "init_func": {
                "type": "string"
              },
              "shutdown": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "auth_handler": {
            "type": "object",
            "required": [
              "name",
              "package"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "package": {
                "type": "string"
              },
              "receiver": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "appRef": {
      "type": "object",
      "required": [
        "name",
        "root",
        "config_path"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "root": {
          "type": "string"
        },
        "config_path": {
          "type": "string"
        },
        "module_path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
