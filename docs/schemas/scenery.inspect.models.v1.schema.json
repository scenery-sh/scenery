{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.inspect.models.v1.schema.json",
  "title": "scenery inspect models v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "app", "models"],
  "properties": {
    "schema_version": { "const": "scenery.inspect.models.v1" },
    "app": { "$ref": "#/$defs/app" },
    "models": {
      "type": "array",
      "items": { "$ref": "#/$defs/model" }
    }
  },
  "$defs": {
    "app": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" },
        "module_path": { "type": "string" }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "package", "file", "line", "table", "fields"],
      "properties": {
        "name": { "type": "string" },
        "package": { "type": "string" },
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "table": { "type": "string" },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/field" }
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "kind"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "kind": { "enum": ["stored", "relationship", "computed"] },
        "column": { "type": "string" },
        "enum_values": { "type": "array", "items": { "type": "string" } },
        "filterable": { "type": "boolean" },
        "renamed_from": { "type": "string" }
      }
    }
  }
}
