{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.durable.worker_token.create.v1.schema.json",
  "title": "scenery.durable.worker_token.create.v1",
  "type": "object",
  "required": ["schema_version", "app", "service", "db_path", "token"],
  "properties": {
    "schema_version": { "const": "scenery.durable.worker_token.create.v1" },
    "app": {
      "type": "object",
      "required": ["name", "root"],
      "properties": {
        "name": { "type": "string" },
        "root": { "type": "string" }
      },
      "additionalProperties": false
    },
    "service": { "type": "string" },
    "db_path": { "type": "string" },
    "token": {
      "type": "object",
      "required": ["id", "name", "secret", "token_hash"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "secret": { "type": "string", "minLength": 32 },
        "token_hash": { "type": "string", "minLength": 64, "maxLength": 64 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
