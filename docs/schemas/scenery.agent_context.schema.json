{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.agent_context.schema.json",
  "title": "scenery agent context",
  "type": "object",
  "required": [
    "kind",
    "schema_revision",
    "generated_at",
    "repo",
    "dirty_files",
    "failing_steps",
    "rerun_commands",
    "changed_area_recommended_commands",
    "recommended_commands",
    "relevant_active_execplans",
    "recent_failed_harness_artifacts",
    "docs_freshness",
    "validation_classification",
    "risk_classification",
    "docs_entrypoints",
    "schemas",
    "known_fast_loop",
    "known_release_loop",
    "architecture_rules"
  ],
  "properties": {
    "kind": {
      "const": "scenery.agent_context"
    },
    "schema_revision": {
      "const": "sha256:52ba6c27a29a23ce2450a3207cf6b2f6d07b0dbd4d7bf0788f03d035b3b34461"
    },
    "generated_at": {
      "type": "string"
    },
    "repo": {
      "type": "object",
      "required": [
        "root",
        "module_path",
        "go_mod_path"
      ],
      "properties": {
        "root": {
          "type": "string"
        },
        "module_path": {
          "const": "scenery.sh"
        },
        "go_mod_path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "current_branch": {
      "type": "string"
    },
    "current_commit": {
      "type": "string"
    },
    "dirty_files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/changed_file"
      }
    },
    "changed_area": {
      "type": "object",
      "additionalProperties": true
    },
    "failing_steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/failing_step"
      }
    },
    "rerun_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changed_area_recommended_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "relevant_active_execplans": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/exec_plan"
      }
    },
    "recent_failed_harness_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/failed_artifact"
      }
    },
    "docs_freshness": {
      "$ref": "#/$defs/docs_freshness"
    },
    "validation_classification": {
      "type": "array",
      "items": {
        "enum": [
          "documentation-only",
          "go-package",
          "cli-json-contract",
          "compiler-or-generator",
          "ui-catalog",
          "dashboard",
          "release-sensitive-or-runtime",
          "repository-fallback"
        ]
      },
      "uniqueItems": true
    },
    "risk_classification": {
      "type": "array",
      "items": {
        "enum": [
          "runtime",
          "CLI contract",
          "dashboard",
          "schema",
          "release",
          "onlv-impacting"
        ]
      }
    },
    "docs_entrypoints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "schemas": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "known_fast_loop": {
      "type": "string"
    },
    "known_release_loop": {
      "type": "string"
    },
    "architecture_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recent_failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "changed_file": {
      "type": "object",
      "required": [
        "path",
        "status",
        "category"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "package": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "failing_step": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "error": {
          "type": "string"
        },
        "first_file_to_read": {
          "type": "string"
        },
        "rerun_command": {
          "type": "string"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_artifact"
          }
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    },
    "exec_plan": {
      "type": "object",
      "required": [
        "path",
        "title"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "failed_artifact": {
      "type": "object",
      "required": [
        "step",
        "name",
        "path"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "schema_revision": {
          "type": "string"
        },
        "step": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "rerun_command": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "docs_freshness": {
      "type": "object",
      "required": [
        "document_count",
        "missing_count",
        "review_due_count",
        "stale_count"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "schema_revision": {
          "type": "string"
        },
        "document_count": {
          "type": "integer"
        },
        "missing_count": {
          "type": "integer"
        },
        "review_due_count": {
          "type": "integer"
        },
        "stale_count": {
          "type": "integer"
        },
        "missing_documents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "review_due_docs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stale_docs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "error": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "evidence_artifact": {
      "type": "object",
      "required": [
        "name",
        "path"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "schema_revision": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
