{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.inspect.endpoints.schema.json",
  "title": "scenery.inspect.endpoints",
  "type": "object",
  "required": [
    "kind",
    "schema_revision",
    "app",
    "endpoints"
  ],
  "properties": {
    "kind": {
      "const": "scenery.inspect.endpoints"
    },
    "schema_revision": {
      "const": "sha256:af1066b46918c1a19a1e24c22e7316c35a406a6d8cfdd04c49e1a1623a797d13"
    },
    "app": {
      "$ref": "#/$defs/appRef"
    },
    "endpoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/endpoint"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "appRef": {
      "type": "object",
      "required": [
        "name",
        "root",
        "config_path"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "root": {
          "type": "string"
        },
        "config_path": {
          "type": "string"
        },
        "module_path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "endpoint": {
      "type": "object",
      "required": [
        "id",
        "service",
        "endpoint",
        "access",
        "raw",
        "path",
        "methods",
        "has_payload"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "service": {
          "type": "string"
        },
        "endpoint": {
          "type": "string"
        },
        "access": {
          "type": "string",
          "enum": [
            "public",
            "auth",
            "private"
          ]
        },
        "raw": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "methods": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "generated": {
          "type": "boolean"
        },
        "has_payload": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  }
}
