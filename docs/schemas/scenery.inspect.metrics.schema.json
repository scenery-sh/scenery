{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.inspect.metrics.schema.json",
  "title": "scenery.inspect.metrics",
  "type": "object",
  "required": [
    "kind",
    "schema_revision",
    "app",
    "query",
    "summary",
    "services",
    "endpoints",
    "logs",
    "meta"
  ],
  "properties": {
    "kind": {
      "const": "scenery.inspect.metrics"
    },
    "schema_revision": {
      "const": "sha256:6af4d264dbb1fd08f82a3b69eac6114dd400100145476bae5f8cdd2fb8f337bd"
    },
    "app": {
      "type": "object",
      "required": [
        "name",
        "root",
        "config_path"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "root": {
          "type": "string"
        },
        "config_path": {
          "type": "string"
        },
        "module_path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "query": {
      "$ref": "#/$defs/query"
    },
    "warnings": {
      "type": "array",
      "items": {
