{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.inspect.traces.v1.schema.json",
  "title": "onlava.inspect.traces.v1",
  "type": "object",
  "required": ["schema_version", "app", "query", "traces"],
  "properties": {
    "schema_version": { "const": "onlava.inspect.traces.v1" },
    "app": {
      "type": "object",
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" },
        "module_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "query": { "$ref": "#/$defs/query" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "traces": {
      "type": "array",
      "items": { "$ref": "#/$defs/trace" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "query": {
      "type": "object",
      "required": ["app_id", "available_filters"],
      "properties": {
        "app_id": { "type": "string" },
        "limit": { "type": "integer" },
        "since": { "type": "string" },
        "since_timestamp": { "type": "string" },
        "service": { "type": "string" },
        "endpoint": { "type": "string" },
        "trace_id": { "type": "string" },
        "status": { "type": "string" },
        "min_duration_ms": { "type": "number" },
        "sort": { "type": "string" },
        "available_filters": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "trace": {
      "type": "object",
      "required": ["trace_id", "span_id", "kind", "status", "started_at", "duration_ms", "duration_nanos"],
      "properties": {
        "trace_id": { "type": "string" },
        "span_id": { "type": "string" },
        "kind": { "type": "string" },
        "status": { "type": "string" },
        "service": { "type": "string" },
        "endpoint": { "type": "string" },
        "topic": { "type": "string" },
        "subscription": { "type": "string" },
        "message_id": { "type": "string" },
        "started_at": { "type": "string" },
        "duration_ms": { "type": "number" },
        "duration_nanos": { "type": "integer" },
        "service_catalog_url": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
