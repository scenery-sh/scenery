{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.inspect.metrics.v1.schema.json",
  "title": "onlava.inspect.metrics.v1",
  "type": "object",
  "required": ["schema_version", "app", "query", "summary", "services", "endpoints", "logs", "meta"],
  "properties": {
    "schema_version": { "const": "onlava.inspect.metrics.v1" },
    "app": {
      "type": "object",
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" },
        "module_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "query": { "$ref": "#/$defs/query" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "summary": {
      "type": "object",
      "required": ["trace_count", "error_count", "error_rate", "event_count", "log_count", "avg_duration_ms", "min_duration_ms", "max_duration_ms", "p50_duration_ms", "p95_duration_ms"],
      "properties": {
        "trace_count": { "type": "integer" },
        "error_count": { "type": "integer" },
        "error_rate": { "type": "number" },
        "event_count": { "type": "integer" },
        "log_count": { "type": "integer" },
        "avg_duration_ms": { "type": "number" },
        "min_duration_ms": { "type": "number" },
        "max_duration_ms": { "type": "number" },
        "p50_duration_ms": { "type": "number" },
        "p95_duration_ms": { "type": "number" },
        "slowest_trace_id": { "type": "string" },
        "slowest_endpoint": { "type": "string" },
        "slowest_service": { "type": "string" },
        "slowest_duration_ms": { "type": "number" }
      },
      "additionalProperties": false
    },
    "services": {
      "type": "array",
      "items": { "$ref": "#/$defs/metric" }
    },
    "endpoints": {
      "type": "array",
      "items": { "$ref": "#/$defs/metric" }
    },
    "logs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["level", "count"],
        "properties": {
          "level": { "type": "string" },
          "count": { "type": "integer" }
        },
        "additionalProperties": false
      }
    },
    "meta": {
      "type": "object",
      "required": ["trace_metric_limit"],
      "properties": {
        "trace_metric_limit": { "type": "integer" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "query": {
      "type": "object",
      "required": ["app_id", "available_filters"],
      "properties": {
        "app_id": { "type": "string" },
        "limit": { "type": "integer" },
        "since": { "type": "string" },
        "since_timestamp": { "type": "string" },
        "service": { "type": "string" },
        "endpoint": { "type": "string" },
        "trace_id": { "type": "string" },
        "status": { "type": "string" },
        "min_duration_ms": { "type": "number" },
        "sort": { "type": "string" },
        "available_filters": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "metric": {
      "type": "object",
      "required": ["count", "error_count", "error_rate", "avg_duration_ms", "min_duration_ms", "max_duration_ms", "p50_duration_ms", "p95_duration_ms"],
      "properties": {
        "service": { "type": "string" },
        "endpoint": { "type": "string" },
        "kind": { "type": "string" },
        "count": { "type": "integer" },
        "error_count": { "type": "integer" },
        "error_rate": { "type": "number" },
        "avg_duration_ms": { "type": "number" },
        "min_duration_ms": { "type": "number" },
        "max_duration_ms": { "type": "number" },
        "p50_duration_ms": { "type": "number" },
        "p95_duration_ms": { "type": "number" }
      },
      "additionalProperties": false
    }
  }
}
