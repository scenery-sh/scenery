    "cutoff": {"type": "string", "format": "date-time"},
    "pruned": {"type": "array", "items": {"type": "string"}},
    "skipped": {"type": "array", "items": {"type": "string"}},
    "db_cleanup": {"type": "boolean"},
    "state_cleanup": {"type": "boolean"},
    "dev_events_pruned": {"type": "integer", "minimum": 0},
