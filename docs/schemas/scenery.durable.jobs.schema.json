{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.durable.jobs.schema.json",
  "title": "scenery.durable.jobs",
  "type": "object",
  "required": [
    "kind",
    "schema_revision",
    "service",
    "db_path"
  ],
  "properties": {
    "kind": {
      "const": "scenery.durable.jobs"
    },
    "schema_revision": {
      "const": "sha256:e680c8870c213d3fba5b8aa35fc7b9fda71e95fc526330f529c108728519f948"
    },
    "service": {
      "type": "string"
    },
    "db_path": {
      "type": "string"
    },
    "action": {
      "enum": [
        "list",
        "inspect",
        "cancel",
        "retry"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "jobs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/job"
      }
    },
    "job": {
      "$ref": "#/$defs/job"
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "job": {
      "type": "object",
      "required": [
        "id",
        "task_name",
        "state",
        "attempt",
        "max_attempts",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "task_name": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "dedupe_key": {
          "type": "string"
        },
        "attempt": {
          "type": "integer",
          "minimum": 0
        },
        "max_attempts": {
          "type": "integer",
          "minimum": 0
        },
        "created_at": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        },
        "completed_at": {
          "type": "string"
        },
        "error_codec": {
          "type": "string"
        },
        "error": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "event": {
      "type": "object",
      "required": [
        "seq",
        "event_type",
        "payload_codec",
        "created_at"
      ],
      "properties": {
        "seq": {
          "type": "integer",
          "minimum": 0
        },
        "attempt": {
          "type": "integer",
          "minimum": 0
        },
        "event_type": {
          "type": "string"
        },
        "payload_codec": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
