{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.inspect.build.schema.json",
  "title": "scenery.inspect.build",
  "type": "object",
  "required": [
    "kind",
    "schema_revision",
    "app",
    "build"
  ],
  "properties": {
    "kind": {
      "const": "scenery.inspect.build"
    },
    "schema_revision": {
      "const": "sha256:5787ddfb761b34a352c20b45dc37f50a85356824ecb7579d00abe36a87e65572"
    },
    "app": {
      "$ref": "#/$defs/appRef"
    },
    "build": {
      "type": "object",
      "required": [
        "workspace_dir",
        "binary_path",
        "workspace_exists",
        "binary_exists",
        "build_state_path",
        "build_state_exists",
        "metadata_present",
        "api_encoding_present",
        "source_file_count",
        "generated_file_count"
      ],
      "properties": {
        "workspace_dir": {
          "type": "string"
        },
        "binary_path": {
          "type": "string"
        },
        "workspace_exists": {
          "type": "boolean"
        },
        "binary_exists": {
          "type": "boolean"
        },
        "build_state_path": {
          "type": "string"
        },
        "build_state_exists": {
          "type": "boolean"
        },
        "build_state_version": {
          "type": "string"
        },
        "dependency_fingerprint": {
          "type": "string"
        },
        "graph_fingerprint": {
          "type": "string"
        },
        "metadata_present": {
          "type": "boolean"
        },
        "api_encoding_present": {
          "type": "boolean"
        },
        "source_file_count": {
          "type": "integer",
          "minimum": 0
        },
        "generated_file_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "appRef": {
      "type": "object",
      "required": [
        "name",
        "root",
        "config_path"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "root": {
          "type": "string"
        },
        "config_path": {
          "type": "string"
        },
        "module_path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
