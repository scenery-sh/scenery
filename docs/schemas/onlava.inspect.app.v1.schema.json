{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.inspect.app.v1.schema.json",
  "title": "onlava.inspect.app.v1",
  "type": "object",
  "required": ["schema_version", "app", "config", "counts", "services"],
  "properties": {
    "schema_version": { "const": "onlava.inspect.app.v1" },
    "app": { "$ref": "#/$defs/appRef" },
    "config": { "$ref": "onlava.config.v1.schema.json" },
    "counts": {
      "type": "object",
      "required": ["packages", "services", "endpoints", "middleware", "auth_handler", "runtime_declarations"],
      "properties": {
        "packages": { "type": "integer", "minimum": 0 },
        "services": { "type": "integer", "minimum": 0 },
        "endpoints": { "type": "integer", "minimum": 0 },
        "middleware": { "type": "integer", "minimum": 0 },
        "auth_handler": { "type": "integer", "minimum": 0 },
        "runtime_declarations": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "services": {
      "type": "array",
      "items": { "type": "string" }
    },
    "auth_handler": {
      "type": "object",
      "required": ["service", "name"],
      "properties": {
        "service": { "type": "string" },
        "name": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "appRef": {
      "type": "object",
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" },
        "module_path": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
