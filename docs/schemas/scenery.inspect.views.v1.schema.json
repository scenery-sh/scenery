{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.inspect.views.v1.schema.json",
  "title": "scenery inspect views v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "app", "views"],
  "properties": {
    "schema_version": { "const": "scenery.inspect.views.v1" },
    "app": { "$ref": "#/$defs/app" },
    "views": {
      "type": "array",
      "items": { "$ref": "#/$defs/view" }
    }
  },
  "$defs": {
    "app": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" },
        "module_path": { "type": "string" }
      }
    },
    "view": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "package", "file", "line", "entity", "projection"],
      "properties": {
        "name": { "type": "string" },
        "kind": { "const": "collection" },
        "package": { "type": "string" },
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "entity": { "type": "string" },
        "route": { "type": "string" },
        "title": { "type": "string" },
        "columns": { "type": "array", "items": { "type": "string" } },
        "projection": { "$ref": "#/$defs/projection" },
        "slots": { "type": "array", "items": { "$ref": "#/$defs/slot" } }
      }
    },
    "projection": {
      "description": "Collection view page-record projection in the model/view IR, mapping a source row type to a page record type.",
      "type": "object",
      "additionalProperties": false,
      "required": ["record_type", "source_row", "fields"],
      "properties": {
        "record_type": { "type": "string" },
        "source_row": { "type": "string" },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/projection_field" }
        }
      }
    },
    "projection_field": {
      "description": "Field carried from the source row into the page projection record.",
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "column", "type", "kind"],
      "properties": {
        "name": { "type": "string" },
        "column": { "type": "string" },
        "type": { "type": "string" },
        "kind": { "enum": ["stored", "relationship", "computed"] }
      }
    },
    "slot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string" }
      }
    }
  }
}
