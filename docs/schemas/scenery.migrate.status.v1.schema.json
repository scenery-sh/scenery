{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.migrate.status.v1.schema.json",
  "title": "Scenery vNext migration status",
  "type": "object",
  "required": ["api_version", "mode", "ready", "services", "constructs", "workspace_revision", "diagnostics"],
  "properties": {
    "api_version": { "const": "scenery.migrate.status.v1" },
    "mode": { "enum": ["legacy_only", "mixed", "native_only"] },
    "frontend": { "type": "string" },
    "legacy_config": { "type": "string" },
    "ready": { "type": "boolean" },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "state", "active", "lifecycle_adapter", "remaining_operation_bridge_count", "adapter_retirement_ready", "legacy_candidate_valid", "native_candidate_valid"],
        "properties": {
          "name": { "type": "string" },
          "state": { "enum": ["legacy", "shadow", "native", "retired"] },
          "active": { "enum": ["legacy", "native"] },
          "package": { "type": "string" },
          "module": { "type": "string" },
          "legacy_target": { "type": "string" },
          "namespace": { "type": "string" },
          "legacy_candidate_digest": { "$ref": "#/$defs/revision" },
          "native_candidate_digest": { "$ref": "#/$defs/revision" },
          "comparison_digest": { "$ref": "#/$defs/revision" },
          "rollback_safety": { "type": "string" },
          "guarantee_classification": { "type": "string" },
          "migration_disposition": { "type": "string" },
          "cutover_classes": { "$ref": "#/$defs/string_list" },
          "lifecycle_adapter": { "enum": ["legacy_go_v0", "native_go_v1"] },
          "remaining_operation_bridge_count": { "type": "integer", "minimum": 0 },
          "adapter_retirement_ready": { "type": "boolean" },
          "legacy_candidate_valid": { "type": "boolean" },
          "native_candidate_valid": { "type": "boolean" },
          "candidate_diagnostics": { "type": "object", "additionalProperties": { "type": "array", "items": { "type": "object" } } }
        },
        "additionalProperties": false
      }
    },
    "constructs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["address", "kind", "service", "state", "active_owner", "guarantee_classification", "migration_disposition", "required_profiles", "missing_profiles", "cutover_class", "stateful_operational_state", "external_identities", "external_aliases", "generated_artifacts", "deployed_consumer_gates", "cli_protocol_dependencies", "operational_evidence", "operational_state_revision", "operational_ready", "semantic_blocking", "rollback_safety", "blocking", "diagnostics"],
        "properties": {
          "address": { "type": "string" },
          "kind": { "type": "string" },
          "service": { "type": "string" },
          "state": { "type": "string" },
          "active_owner": { "enum": ["legacy", "native"] },
          "shadow_owner": { "enum": ["legacy", "native"] },
          "guarantee_classification": { "type": "string" },
          "migration_disposition": { "type": "string" },
          "legacy_candidate_digest": { "$ref": "#/$defs/revision" },
          "native_candidate_digest": { "$ref": "#/$defs/revision" },
          "comparison_digest": { "$ref": "#/$defs/revision" },
          "required_profiles": { "$ref": "#/$defs/string_list" },
          "missing_profiles": { "$ref": "#/$defs/string_list" },
          "cutover_class": { "type": "string" },
          "stateful_operational_state": {
            "type": "object",
            "required": ["drain", "fence", "cursor"],
            "properties": { "drain": { "type": "string" }, "fence": { "type": "string" }, "cursor": { "type": "string" } },
            "additionalProperties": false
          },
          "external_identities": { "$ref": "#/$defs/string_list" },
          "external_aliases": { "$ref": "#/$defs/string_list" },
          "generated_artifacts": { "$ref": "#/$defs/string_list" },
          "deployed_consumer_gates": {
            "type": "array",
            "items": {
              "type": "object", "required": ["artifact", "state", "evidence"],
              "properties": { "artifact": { "type": "string" }, "state": { "type": "string" }, "evidence": { "$ref": "#/$defs/string_list" } },
              "additionalProperties": false
            }
          },
          "cli_protocol_dependencies": {
            "type": "array",
            "items": {
              "type": "object", "required": ["api_version", "state"],
              "properties": { "api_version": { "type": "string" }, "state": { "type": "string" } },
              "additionalProperties": false
            }
          },
          "operational_evidence": { "type": "object", "additionalProperties": { "$ref": "#/$defs/string_list" } },
          "operational_state_revision": { "$ref": "#/$defs/revision" },
          "operational_ready": { "type": "boolean" },
          "semantic_blocking": { "type": "boolean" },
          "rollback_safety": { "type": "string" },
          "blocking": { "type": "boolean" },
          "diagnostics": { "type": "array", "items": { "type": "object" } }
        },
        "additionalProperties": false
      }
    },
    "workspace_revision": { "$ref": "#/$defs/revision" },
    "contract_revision": { "$ref": "#/$defs/revision" },
    "operational_state_revision": { "$ref": "#/$defs/revision" },
    "diagnostics": { "type": "array" }
  },
  "$defs": {
    "revision": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "string_list": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  },
  "additionalProperties": false
}
