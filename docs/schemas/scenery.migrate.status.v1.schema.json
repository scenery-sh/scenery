{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.migrate.status.v1.schema.json",
  "title": "Scenery vNext migration status",
  "type": "object",
  "required": ["api_version", "mode", "ready", "services", "workspace_revision", "diagnostics"],
  "properties": {
    "api_version": { "const": "scenery.migrate.status.v1" },
    "mode": { "enum": ["legacy_only", "mixed", "native_only"] },
    "frontend": { "type": "string" },
    "legacy_config": { "type": "string" },
    "ready": { "type": "boolean" },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "state", "active"],
        "properties": {
          "name": { "type": "string" },
          "state": { "enum": ["legacy", "shadow", "native", "retired"] },
          "active": { "enum": ["legacy", "native"] },
          "package": { "type": "string" },
          "module": { "type": "string" },
          "legacy_target": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "workspace_revision": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "contract_revision": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "diagnostics": { "type": "array" }
  },
  "additionalProperties": false
}
