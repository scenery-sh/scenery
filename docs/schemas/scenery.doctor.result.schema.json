{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.doctor.result.schema.json",
  "title": "scenery doctor result",
  "type": "object",
  "required": [
    "kind",
    "schema_revision",
    "ok",
    "summary",
    "scenery",
    "environment",
    "checks"
  ],
  "additionalProperties": false,
  "properties": {
    "kind": {
      "const": "scenery.doctor.result"
    },
    "schema_revision": {
      "const": "sha256:1c9484e483506f4a9a82a134e5f4a84e6664166b4051cfe9bbe680d477bedaa6"
    },
    "ok": {
      "type": "boolean"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "scenery": {
      "$ref": "scenery.version.schema.json"
    },
    "app": {
      "$ref": "#/$defs/app"
    },
    "environment": {
      "$ref": "#/$defs/environment"
    },
    "deploy": {
      "$ref": "#/$defs/deploy"
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    }
  },
  "$defs": {
    "summary": {
      "type": "object",
      "required": [
        "ok",
        "warnings",
        "errors",
        "skipped"
      ],
      "additionalProperties": false,
      "properties": {
        "ok": {
          "type": "integer",
          "minimum": 0
        },
        "warnings": {
          "type": "integer",
          "minimum": 0
        },
        "errors": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "app": {
      "type": "object",
      "required": [
        "root",
        "config_path",
        "name"
      ],
      "additionalProperties": false,
      "properties": {
        "root": {
          "type": "string",
          "minLength": 1
        },
        "config_path": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string"
        }
      }
    },
    "environment": {
      "type": "object",
      "required": [
        "goos",
        "goarch",
        "num_cpu",
        "paths"
      ],
      "additionalProperties": false,
      "properties": {
        "goos": {
          "type": "string",
          "minLength": 1
        },
        "goarch": {
          "type": "string",
          "minLength": 1
        },
        "num_cpu": {
          "type": "integer",
          "minimum": 0
        },
        "total_memory_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "paths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/path_report"
          }
        }
      }
    },
    "path_report": {
      "type": "object",
      "required": [
        "kind",
        "path"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "free_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "total_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "deploy": {
      "type": "object",
      "required": [
        "kind",
        "schema_revision",
        "ready",
        "registry_path",
        "targets",
        "diagnostics"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "scenery.doctor.deploy"
        },
        "schema_revision": {
          "const": "sha256:212b8e95bb1af8f330b1a0a4a88f6611294f7832dfff5a002511df9a9e7b1294"
        },
        "ready": {
          "type": "boolean"
        },
        "registry_path": {
          "type": "string"
        },
        "targets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/deploy_target"
          }
        },
        "diagnostics": {
          "$ref": "#/$defs/deploy_diagnostics"
        }
      }
    },
    "deploy_target": {
      "type": "object",
      "required": [
        "domain",
        "app_root",
        "enabled",
        "live_session",
        "cert_present"
      ],
      "additionalProperties": false,
      "properties": {
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "app_root": {
          "type": "string",
          "minLength": 1
        },
        "root_service": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "live_session": {
          "type": "boolean"
        },
        "session_id": {
          "type": "string"
        },
        "cert_present": {
          "type": "boolean"
        },
        "cert_not_after": {
          "type": "string",
          "format": "date-time"
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "deploy_diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lan_ip": {
          "type": "string"
        },
        "public_ip": {
          "type": "string"
        },
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/deploy_diagnostic_check"
          }
        }
      }
    },
    "deploy_diagnostic_check": {
      "type": "object",
      "required": [
        "id",
        "status",
        "message"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "ok",
            "warn",
            "error",
            "skipped"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "suggested_action": {
          "type": "string"
        },
        "observed": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "check": {
      "type": "object",
      "required": [
        "id",
        "category",
        "name",
        "status",
        "severity",
        "message"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "ok",
            "warn",
            "error",
            "skipped"
          ]
        },
        "severity": {
          "enum": [
            "required",
            "optional",
            "informational"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "suggested_action": {
          "type": "string"
        },
        "observed": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
