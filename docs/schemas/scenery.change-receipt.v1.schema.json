{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.change-receipt.v1.schema.json",
  "title": "Scenery semantic change receipt",
  "type": "object",
  "required": ["api_version", "plan_id", "workspace_revision", "contract_revision", "implementation_revision_status", "deployment_revision_status", "applied"],
  "properties": {
    "api_version": { "const": "scenery.change-receipt/v1" },
    "plan_id": { "$ref": "#/$defs/revision" },
    "workspace_revision": { "$ref": "#/$defs/revision" },
    "contract_revision": { "$ref": "#/$defs/revision" },
    "implementation_revision_status": { "type": "string", "minLength": 1 },
    "deployment_revision_status": { "type": "string", "minLength": 1 },
    "applied": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  },
  "$defs": { "revision": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" } },
  "additionalProperties": false
}
