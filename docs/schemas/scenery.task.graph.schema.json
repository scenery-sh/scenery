{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.task.graph.schema.json",
  "title": "scenery.task.graph",
  "type": "object",
  "required": [
    "kind",
    "schema_revision",
    "app",
    "nodes",
    "edges"
  ],
  "properties": {
    "kind": {
      "const": "scenery.task.graph"
    },
    "schema_revision": {
      "const": "sha256:6897eba81ccdf4dc44c1c4d859f2c9e4bea6a4b49bf8fe52df07bec5c111f3d4"
    },
    "app": {
      "$ref": "#/$defs/appRef"
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task"
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "appRef": {
      "type": "object",
      "required": [
        "name",
        "root",
        "config_path"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "root": {
          "type": "string"
        },
        "config_path": {
          "type": "string"
        },
        "module_path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "task": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        },
        "run": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "env_keys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "node": {
      "type": "object",
      "required": [
        "target",
        "kind"
      ],
      "properties": {
        "target": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "configured",
            "code",
            "builtin"
          ]
        },
        "source": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "args_accepted": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": [
        "from",
        "to",
        "kind"
      ],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
