{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.library-generated.schema.json",
  "title": "Scenery generated Go library linkage descriptor",
  "type": "object",
  "required": ["kind", "schema_revision", "spec_revision", "producer", "artifact_kind", "library", "version", "abi_hash", "facade_import", "implementation_import", "content_digest", "generator", "covered", "files"],
  "properties": {
    "kind": { "const": "scenery.library-generated" },
    "schema_revision": { "$ref": "#/$defs/revision" },
    "spec_revision": { "$ref": "#/$defs/revision" },
    "producer": { "type": "object" },
    "artifact_kind": { "const": "go_library_linkage" },
    "library": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$" },
    "abi_hash": { "$ref": "#/$defs/revision" },
    "facade_import": { "type": "string", "minLength": 1 },
    "implementation_import": { "type": "string", "minLength": 1 },
    "content_digest": { "$ref": "#/$defs/revision" },
    "generator": { "type": "string", "minLength": 1 },
    "covered": { "$ref": "#/$defs/string_list" },
    "files": { "$ref": "#/$defs/string_list" }
  },
  "$defs": {
    "revision": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "string_list": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  },
  "additionalProperties": false
}
