{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.metrics.labels.v1.schema.json",
  "title": "onlava.metrics.labels.v1",
  "type": "object",
  "required": ["schema_version", "scope", "backend", "query", "labels"],
  "properties": {
    "schema_version": { "const": "onlava.metrics.labels.v1" },
    "scope": { "$ref": "onlava.inspect.observability.v1.schema.json#/$defs/scope" },
    "backend": { "$ref": "onlava.inspect.observability.v1.schema.json#/$defs/backend" },
    "query": { "$ref": "#/$defs/query" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "labels": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false,
  "$defs": {
    "query": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "match": { "type": "string" },
        "since": { "type": "string" },
        "start": { "type": "string" },
        "end": { "type": "string" },
        "timeout": { "type": "string" },
        "limit": { "type": "integer" }
      },
      "additionalProperties": false
    }
  }
}
