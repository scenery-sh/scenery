{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.inspect.paths.v1.schema.json",
  "title": "onlava.inspect.paths.v1",
  "type": "object",
  "required": ["schema_version", "app", "paths"],
  "properties": {
    "schema_version": { "const": "onlava.inspect.paths.v1" },
    "app": { "$ref": "#/$defs/appRef" },
    "paths": {
      "type": "object",
      "required": ["app_root", "config_path", "cache_root", "build_root", "workspace_dir", "binary_path", "build_state_path"],
      "properties": {
        "app_root": { "type": "string" },
        "config_path": { "type": "string" },
        "cache_root": { "type": "string" },
        "build_root": { "type": "string" },
        "workspace_dir": { "type": "string" },
        "binary_path": { "type": "string" },
        "build_state_path": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "appRef": {
      "type": "object",
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" },
        "module_path": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
