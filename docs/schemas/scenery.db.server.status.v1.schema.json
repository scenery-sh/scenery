{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.db.server.status.v1.schema.json",
  "title": "scenery db server status",
  "type": "object",
  "required": ["schema_version", "ok", "container", "status"],
  "properties": {
    "schema_version": { "const": "scenery.db.server.status.v1" },
    "ok": { "type": "boolean" },
    "container": { "type": "string" },
    "image": { "type": "string" },
    "status": { "type": "string" },
    "port": { "type": "integer" },
    "url": { "type": "string" },
    "state_path": { "type": "string" },
    "databases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "size_bytes": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "leases": {
      "type": "object",
      "additionalProperties": { "type": "object" }
    }
  },
  "additionalProperties": false
}
