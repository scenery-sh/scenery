{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.harness.test_timing.v1.schema.json",
  "title": "onlava harness test timing report",
  "type": "object",
  "required": ["schema_version", "command", "total_seconds", "packages", "budgets"],
  "properties": {
    "schema_version": {
      "const": "onlava.harness.test_timing.v1"
    },
    "command": {
      "type": "array",
      "items": { "type": "string" }
    },
    "env": {
      "type": "array",
      "items": { "type": "string" }
    },
    "total_seconds": {
      "type": "number"
    },
    "packages": {
      "type": "array",
      "items": { "$ref": "#/$defs/package_timing" }
    },
    "slow_tests": {
      "type": "array",
      "items": { "$ref": "#/$defs/test_timing" }
    },
    "budgets": {
      "type": "object",
      "required": ["total_seconds", "package_seconds", "test_seconds", "mode"],
      "properties": {
        "total_seconds": { "type": "number" },
        "package_seconds": { "type": "number" },
        "test_seconds": { "type": "number" },
        "mode": { "type": "string" }
      },
      "additionalProperties": false
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "package_timing": {
      "type": "object",
      "required": ["package", "seconds"],
      "properties": {
        "package": { "type": "string" },
        "seconds": { "type": "number" },
        "slow_tests": {
          "type": "array",
          "items": { "$ref": "#/$defs/test_timing" }
        }
      },
      "additionalProperties": false
    },
    "test_timing": {
      "type": "object",
      "required": ["name", "package", "seconds"],
      "properties": {
        "name": { "type": "string" },
        "package": { "type": "string" },
        "seconds": { "type": "number" }
      },
      "additionalProperties": false
    }
  }
}
