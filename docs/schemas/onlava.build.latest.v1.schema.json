{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.build.latest.v1.schema.json",
  "title": "onlava.build.latest.v1",
  "type": "object",
  "required": ["schema_version", "app", "build"],
  "properties": {
    "schema_version": { "const": "onlava.build.latest.v1" },
    "app": {
      "type": "object",
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "build": {
      "type": "object",
      "required": [
        "phase",
        "workspace_dir",
        "binary_path",
        "workspace_exists",
        "binary_exists",
        "build_state_path",
        "build_state_exists",
        "metadata_present",
        "api_encoding_present",
        "source_file_count",
        "generated_file_count"
      ],
      "properties": {
        "phase": { "type": "string", "enum": ["prepared", "primed", "compiled"] },
        "workspace_dir": { "type": "string" },
        "binary_path": { "type": "string" },
        "workspace_exists": { "type": "boolean" },
        "binary_exists": { "type": "boolean" },
        "build_state_path": { "type": "string" },
        "build_state_exists": { "type": "boolean" },
        "build_state_version": { "type": "string" },
        "dependency_fingerprint": { "type": "string" },
        "graph_fingerprint": { "type": "string" },
        "metadata_present": { "type": "boolean" },
        "api_encoding_present": { "type": "boolean" },
        "source_file_count": { "type": "integer", "minimum": 0 },
        "generated_file_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
