{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.admin.result.v1.schema.json",
  "title": "onlava.admin.result.v1",
  "description": "Reserved schema for future `onlava admin ... --json` responses.",
  "type": "object",
  "required": ["schema_version", "ok", "command"],
  "properties": {
    "schema_version": { "const": "onlava.admin.result.v1" },
    "ok": { "type": "boolean" },
    "command": { "type": "string" },
    "app": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "root": { "type": "string" }
      },
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "data": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
