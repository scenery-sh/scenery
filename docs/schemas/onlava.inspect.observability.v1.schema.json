{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.inspect.observability.v1.schema.json",
  "title": "onlava.inspect.observability.v1",
  "type": "object",
  "required": ["schema_version", "app", "scope", "backends", "examples"],
  "properties": {
    "schema_version": { "const": "onlava.inspect.observability.v1" },
    "app": { "$ref": "#/$defs/app" },
    "scope": { "$ref": "#/$defs/scope" },
    "backends": {
      "type": "object",
      "required": ["logs", "metrics", "traces"],
      "properties": {
        "logs": { "$ref": "#/$defs/backend" },
        "metrics": { "$ref": "#/$defs/backend" },
        "traces": { "$ref": "#/$defs/backend" }
      },
      "additionalProperties": false
    },
    "debug": {
      "type": "object",
      "properties": {
        "base_urls": {
          "type": "object",
          "properties": {
            "logs": { "type": "string" },
            "metrics": { "type": "string" },
            "traces": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "examples": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false,
  "$defs": {
    "app": {
      "type": "object",
      "required": ["id", "name", "root"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "root": { "type": "string" }
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": ["app_id", "session_id", "app_root", "app_root_hash", "enforced"],
      "properties": {
        "app_id": { "type": "string" },
        "session_id": { "type": "string" },
        "app_root": { "type": "string" },
        "app_root_hash": { "type": "string" },
        "worktree": { "type": "string" },
        "branch": { "type": "string" },
        "enforced": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "backend": {
      "type": "object",
      "required": ["kind", "dialect", "ready"],
      "properties": {
        "kind": { "type": "string" },
        "dialect": { "type": "string" },
        "base_url": { "type": "string" },
        "ready": { "type": "boolean" },
        "query_path": { "type": "string" },
        "tail_path": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
