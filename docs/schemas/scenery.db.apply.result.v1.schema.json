{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.db.apply.result.v1.schema.json",
  "title": "scenery.db.apply.result.v1",
  "type": "object",
  "required": ["schema_version", "app", "apply"],
  "properties": {
    "schema_version": { "const": "scenery.db.apply.result.v1" },
    "app": { "$ref": "#/$defs/appRef" },
    "apply": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "command": { "type": "string" },
        "cwd": { "type": "string" },
        "status": { "const": "applied" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "appRef": {
      "type": "object",
      "required": ["name", "root", "config_path"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" },
        "root": { "type": "string" },
        "config_path": { "type": "string" },
        "module_path": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
