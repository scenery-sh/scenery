{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.generated.v1.schema.json",
  "title": "Scenery generated Go application adapter descriptor",
  "type": "object",
  "required": ["api_version", "artifact_kind", "contract_revision", "implementation_revision", "package_contract_abi_revisions", "runtime_abi", "runtime_abi_range", "provider_capability_abis", "http_surface_revisions", "openapi_revisions", "content_digest", "generator", "generator_version", "covered", "files"],
  "properties": {
    "api_version": { "const": "scenery.generated.v1" },
    "artifact_kind": { "const": "go_application_adapters" },
    "contract_revision": { "$ref": "#/$defs/revision" },
    "implementation_revision": { "oneOf": [{ "$ref": "#/$defs/revision_map" }, { "type": "null" }] },
    "package_contract_abi_revisions": { "$ref": "#/$defs/revision_map" },
    "runtime_abi": { "type": "string", "minLength": 1 },
    "runtime_abi_range": { "type": "string", "minLength": 1 },
    "provider_capability_abis": { "type": "object", "additionalProperties": { "type": "object", "additionalProperties": { "type": "string" } } },
    "http_surface_revisions": { "$ref": "#/$defs/revision_map" },
    "openapi_revisions": { "$ref": "#/$defs/revision_map" },
    "content_digest": { "$ref": "#/$defs/revision" },
    "generator": { "type": "string", "minLength": 1 },
    "generator_version": { "type": "string", "minLength": 1 },
    "covered": { "$ref": "#/$defs/string_list" },
    "files": { "$ref": "#/$defs/string_list" }
  },
  "$defs": {
    "revision": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "revision_map": { "type": "object", "additionalProperties": { "$ref": "#/$defs/revision" } },
    "string_list": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  },
  "additionalProperties": false
}
