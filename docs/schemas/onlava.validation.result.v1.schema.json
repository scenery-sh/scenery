{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlava.com/schemas/onlava.validation.result.v1.schema.json",
  "title": "onlava.validation.result.v1",
  "type": "object",
  "required": ["schema_version", "ok", "generated_at", "app", "profile", "selection", "steps"],
  "properties": {
    "schema_version": { "const": "onlava.validation.result.v1" },
    "ok": { "type": "boolean" },
    "generated_at": { "type": "string" },
    "app": { "type": "object", "additionalProperties": true },
    "profile": { "type": "string" },
    "selection": { "type": "object", "additionalProperties": true },
    "steps": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "artifacts": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "diagnostics": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "wrote": { "type": "string" }
  },
  "additionalProperties": false
}
