{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scenery.sh/schemas/scenery.storage.list.v1.schema.json",
  "title": "scenery.storage.list.v1",
  "type": "object",
  "required": ["schema_version", "store", "page"],
  "properties": {
    "schema_version": { "const": "scenery.storage.list.v1" },
    "store": { "type": "string" },
    "page": {
      "type": "object",
      "required": ["objects"],
      "properties": {
        "objects": {
          "type": "array",
          "items": { "$ref": "scenery.storage.object.v1.schema.json#/properties/object" }
        },
        "prefixes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "next_cursor": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
